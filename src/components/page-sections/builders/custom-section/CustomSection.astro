---
import Component from "@components/utils/renderBlock.astro";
import { slugifyLabel } from "@components/utils/slugify";
import Image from "@core-elements/image/Image.astro";

const {
  label,
  contentSections,
  maxContentWidth,
  paddingHorizontal,
  paddingVertical = "4xl",
  colorScheme = "inherit",
  backgroundColor,
  backgroundImage,
  rounded = false,
  editable = false,
  class: className,
  _component,
  "data-children-prop": childrenDataProp,
  ...htmlAttributes
} = Astro.props;

const {
  source = "",
  alt = "",
  positionVertical = "top",
  positionHorizontal = "center",
  priority = false,
} = backgroundImage || {};

if (!htmlAttributes.id && label) {
  htmlAttributes.id = slugifyLabel(label);
}

const hasContentSections = contentSections !== undefined;
const effectiveChildrenProp = childrenDataProp ?? (editable ? "contentSections" : null);
const arrayDataAttributes = effectiveChildrenProp && hasContentSections
  ? { "data-editable": "array", "data-prop": effectiveChildrenProp }
  : {};
---

<section
  class:list={["custom-section", rounded && "rounded", className]}
  data-theme={colorScheme && colorScheme !== "inherit" ? colorScheme : undefined}
  {...htmlAttributes}
>
  <Image
    class:list={["background-image"]}
    source={source}
    alt={alt}
    priority={priority}
    editable={hasContentSections && !!effectiveChildrenProp}
    data-prop-src="backgroundImage.source"
    data-prop-alt="backgroundImage.alt"
    positionVertical={positionVertical}
    positionHorizontal={positionHorizontal}
    background={true}
  />
  {
    backgroundColor && (
      <div class:list={["background", backgroundColor && `bg-${backgroundColor}`]} />
    )
  }

  <div class="outer-content">
    <div
      class:list={[
        "content",
        paddingHorizontal && `pad-x-${paddingHorizontal}`,
        paddingVertical && `pad-y-${paddingVertical}`,
        maxContentWidth && `max-width-${maxContentWidth}`,
      ]}
      {...arrayDataAttributes}
    >
      <slot>
        {contentSections && <Component contentSections={contentSections} editable={!!effectiveChildrenProp} />}
      </slot>
    </div>
  </div>
</section>

<style is:global>
  @layer components {
    .custom-section {
      position: relative;
    }

    .custom-section.rounded {
      border-radius: var(--radius-xl);
      overflow: hidden;
    }

    .custom-section > .outer-content {
      height: 100%;
    }

    .custom-section > .outer-content > .content {
      container-type: inline-size;
      height: 100%;
      margin-inline: auto;
      position: relative;
      z-index: var(--layer-1);
    }

    .custom-section
      > .outer-content
      > .content
      > [data-editable="array-item"]:first-child
      > *:first-child,
    .custom-section > .outer-content > .content > :not([data-editable="array-item"]):first-child {
      margin-top: 0 !important;
    }

    .custom-section
      > .outer-content
      > .content
      > [data-editable="array-item"]:last-child
      > *:last-child,
    .custom-section > .outer-content > .content > :not([data-editable="array-item"]):last-child {
      margin-bottom: 0 !important;
    }

    .custom-section > .outer-content > .content.pad-x-xs {
      padding-inline: var(--spacing-xs);
    }

    .custom-section > .outer-content > .content.pad-x-sm {
      padding-inline: var(--spacing-sm);
    }

    .custom-section > .outer-content > .content.pad-x-md {
      padding-inline: var(--spacing-md);
    }

    .custom-section > .outer-content > .content.pad-x-lg {
      padding-inline: var(--spacing-lg);
    }

    .custom-section > .outer-content > .content.pad-x-xl {
      padding-inline: var(--spacing-xl);
    }

    .custom-section > .outer-content > .content.pad-x-2xl {
      padding-inline: var(--spacing-2xl);
    }

    .custom-section > .outer-content > .content.pad-x-3xl {
      padding-inline: var(--spacing-3xl);
    }

    .custom-section > .outer-content > .content.pad-x-4xl {
      padding-inline: var(--spacing-4xl);
    }

    .custom-section > .outer-content > .content.pad-x-5xl {
      padding-inline: var(--spacing-5xl);
    }

    .custom-section > .outer-content > .content.pad-x-6xl {
      padding-inline: var(--spacing-6xl);
    }

    .custom-section > .outer-content > .content.pad-y-xs {
      padding-block: var(--spacing-xs);
    }

    .custom-section > .outer-content > .content.pad-y-sm {
      padding-block: var(--spacing-sm);
    }

    .custom-section > .outer-content > .content.pad-y-md {
      padding-block: var(--spacing-md);
    }

    .custom-section > .outer-content > .content.pad-y-lg {
      padding-block: var(--spacing-lg);
    }

    .custom-section > .outer-content > .content.pad-y-xl {
      padding-block: var(--spacing-xl);
    }

    .custom-section > .outer-content > .content.pad-y-2xl {
      padding-block: var(--spacing-2xl);
    }

    .custom-section > .outer-content > .content.pad-y-3xl {
      padding-block: var(--spacing-3xl);
    }

    .custom-section > .outer-content > .content.pad-y-4xl {
      padding-block: var(--spacing-4xl);
    }

    .custom-section > .outer-content > .content.pad-y-5xl {
      padding-block: var(--spacing-5xl);
    }

    .custom-section > .outer-content > .content.pad-y-6xl {
      padding-block: var(--spacing-6xl);
    }

    @media (width < 640px) {
      .custom-section > .outer-content > .content.pad-y-xs {
        padding-block: var(--spacing-xs);
      }

      .custom-section > .outer-content > .content.pad-y-sm {
        padding-block: var(--spacing-xs);
      }

      .custom-section > .outer-content > .content.pad-y-md {
        padding-block: var(--spacing-sm);
      }

      .custom-section > .outer-content > .content.pad-y-lg {
        padding-block: var(--spacing-md);
      }

      .custom-section > .outer-content > .content.pad-y-xl {
        padding-block: var(--spacing-md);
      }

      .custom-section > .outer-content > .content.pad-y-2xl {
        padding-block: var(--spacing-lg);
      }

      .custom-section > .outer-content > .content.pad-y-3xl {
        padding-block: var(--spacing-xl);
      }

      .custom-section > .outer-content > .content.pad-y-4xl {
        padding-block: var(--spacing-2xl);
      }

      .custom-section > .outer-content > .content.pad-y-5xl {
        padding-block: var(--spacing-3xl);
      }

      .custom-section > .outer-content > .content.pad-y-6xl {
        padding-block: var(--spacing-4xl);
      }
    }

    .custom-section > .outer-content > .content.max-width-xs {
      max-width: var(--content-width-xs);
    }

    .custom-section > .outer-content > .content.max-width-sm {
      max-width: var(--content-width-sm);
    }

    .custom-section > .outer-content > .content.max-width-md {
      max-width: var(--content-width-md);
    }

    .custom-section > .outer-content > .content.max-width-lg {
      max-width: var(--content-width-lg);
    }

    .custom-section > .outer-content > .content.max-width-xl {
      max-width: var(--content-width-xl);
    }

    .custom-section > .outer-content > .content.max-width-2xl {
      max-width: var(--content-width-2xl);
    }

    .custom-section > .outer-content > .content.max-width-3xl {
      max-width: var(--content-width-3xl);
    }

    .custom-section > .background {
      inset: 0;
      position: absolute;
    }

    .custom-section > .background-image {
      z-index: var(--layer-1);
    }

    .custom-section > .bg-base {
      background-color: var(--color-bg);
    }

    .custom-section > .bg-surface {
      background-color: var(--color-bg-surface);
    }

    .custom-section > .bg-accent {
      background-color: var(--color-bg-accent);
    }

    .custom-section > .bg-highlight {
      background-color: var(--color-bg-highlight);
    }
  }
</style>
