---
import ContentSelectorPanel from "./ContentSelectorPanel.astro";
import { slugifyLabel } from "@components/utils/slugify";
import type { ContentSelectorItem } from "../../../../types";

const {
  items = [] as ContentSelectorItem[],
  navigationPosition = "start",
  class: className,
  label,
  editable = false,
  "data-children-prop": childrenDataProp = "items",
  _component,
  ...htmlAttributes
} = Astro.props;

if (!htmlAttributes.id && label) {
  htmlAttributes.id = slugifyLabel(label);
}

const uniqueId = crypto.randomUUID();
const groupName = `tabs-${uniqueId}`;

const arrayDataAttributes = editable
  ? {
      "data-editable": "array",
      "data-prop": childrenDataProp,
    }
  : {};

const hasItems = items?.length > 0;
const hasSlotContent = Astro.slots.has("default");

if (!_component && !hasItems && !hasSlotContent) return;
---

<section
  class:list={["content-selector", `nav-${navigationPosition}`, className]}
  data-uid={uniqueId}
  {...htmlAttributes}
>
  <div class="content-selector-items" role="tablist" {...arrayDataAttributes}>
    <slot>
      {
        items?.map((item: ContentSelectorItem, index: number) => (
          <ContentSelectorPanel
            title={item.title}
            contentSections={item.contentSections}
            _component={item._component}
            checked={index === 0}
            groupName={groupName}
            navigationPosition={navigationPosition}
            editable={editable}
            data-editable="array-item"
          />
        ))
      }
    </slot>
  </div>
</section>

<style is:global>
  @layer components {
    .content-selector {
      --content-selector-border-width: 1px;
      margin-top: var(--spacing-lg);

      > .content-selector-items {
        border: 0 solid var(--color-bg-muted);
        width: 100%;
      }

      .content-selector-tab {
        background: transparent;
        border: none;
        cursor: pointer;
        display: block;
        padding: var(--spacing-md);
        position: relative;
        transition: background-color var(--animation-normal) ease-in-out;
        width: 100%;

        &::before {
          background: transparent;
          content: "";
          position: absolute;
          transition:
            transform var(--animation-normal),
            background var(--animation-normal);
        }

        &:hover {
          background: var(--color-state-hover);
        }

        > .content-selector-tab-heading {
          margin: 0;
        }
      }

      .content-selector-item > .content-selector-input:checked + .content-selector-tab::before {
        background: var(--color-border-strong);
      }

      .content-selector-item
        > .content-selector-input:checked
        + .content-selector-tab
        + .content-selector-panel {
        display: block;
      }

      &:not(:has(.content-selector-item > .content-selector-input:checked))
        .content-selector-item:first-of-type
        > .content-selector-tab::before {
        background: var(--color-border-strong);
      }

      &:not(:has(.content-selector-item > .content-selector-input:checked))
        .content-selector-item:first-of-type
        > .content-selector-panel {
        display: block;
      }

      &.nav-start {
        > .content-selector-items {
          column-gap: var(--spacing-em-lg);
          display: grid;
          grid-template-columns: minmax(10rem, 20rem) minmax(0, 1fr);
        }

        .content-selector-tab {
          border-inline-start: var(--content-selector-border-width) solid var(--color-bg-muted);
          grid-column: 1;

          &::before {
            inset-block: 0;
            inset-inline-start: calc(var(--content-selector-border-width) * -1);
            width: var(--content-selector-border-width);
          }
        }

        .content-selector-panel {
          grid-column: 2;
          grid-row: 1 / span 999;
          padding: 0 var(--spacing-md);
          width: 100%;
        }
      }

      &.nav-top {
        > .content-selector-items {
          border-bottom-width: var(--content-selector-border-width);
          display: flex;
          flex-wrap: wrap;
        }

        .content-selector-tab {
          width: fit-content;

          &::before {
            height: var(--content-selector-border-width);
            inset-block: 100%;
            inset-inline-start: 0;
            width: 100%;
          }
        }

        .content-selector-panel {
          flex-basis: 100%;
          margin-top: var(--spacing-md);
          padding: 0 var(--spacing-md);
          width: 100%;
        }
      }
    }
  }
</style>
