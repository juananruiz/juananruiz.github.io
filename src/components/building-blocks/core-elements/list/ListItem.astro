---
import Icon from "@core-elements/icon/Icon.astro";
import MarkdownIt from "markdown-it";

const {
  text = "",
  iconName,
  iconColor = "default",
  showIcon = true,
  class: className,
  editable = false,
  "data-prop": customDataProp,
  _component,
  ...htmlAttributes
} = Astro.props;

const md = new MarkdownIt({ html: true });

const effectiveDataProp = customDataProp ?? (editable ? "text" : null);
const textDataAttributes = effectiveDataProp
  ? { "data-editable": "text", "data-prop": effectiveDataProp }
  : {};
---

<li
  class:list={["item", showIcon && iconName && "list-item-has-icon", className]}
  {...htmlAttributes}
>
  {
    showIcon && iconName && (
      <Icon name={iconName} color={iconColor} size="none" class="list-icon" aria-hidden="true" />
    )
  }
  <p {...textDataAttributes}>
    {text ? <Fragment set:html={md.renderInline(text)} /> : <slot />}
  </p>
</li>

<style is:global>
  @layer components {
    .item {
      &.list-item-has-icon {
        display: block;
      }

      > p {
        display: inline;
        font-size: inherit;
        margin: 0;
      }

      > .list-icon {
        display: inline-block;
        flex-shrink: 0;
        height: 1em;
        margin-right: var(--spacing-em-xs);
        vertical-align: -0.15em;
        width: 1em;

        svg {
          display: block;
          height: 100%;
          width: 100%;
        }
      }
    }
  }
</style>
