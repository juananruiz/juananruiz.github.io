---
import RenderBlock from "@components/utils/renderBlock.astro";

const {
  action,
  formBlocks = [],
  class: className,
  _component,
  editable = false,
  "data-children-prop": childrenDataProp = "formBlocks",
  ...htmlAttributes
} = Astro.props;

const arrayDataAttributes = editable
  ? {
      "data-editable": "array",
      "data-prop": childrenDataProp,
    }
  : {};

const hasFormBlocks = formBlocks?.length > 0;
const hasSlotContent = Astro.slots.has("default");
const usesFormBlocks = !hasSlotContent;

if (!_component && !hasFormBlocks && !usesFormBlocks) return;
---

<form
  class:list={["form", className]}
  action={action}
  method="post"
  enctype="multipart/form-data"
  {...htmlAttributes}
>
  <div {...arrayDataAttributes}>
    <slot>
      {formBlocks && <RenderBlock contentSections={formBlocks} />}
    </slot>
  </div>
</form>

<style is:global>
  @layer components {
    .form {
      margin-top: var(--spacing-lg);
      width: 100%;
    }
  }
</style>
